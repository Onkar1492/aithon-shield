# ─────────────────────────────────────────────────────────────────────
# Aithon Shield — Environment Configuration Template
# P6-I3: Self-hosted / air-gap deployment
#
# Copy this file:  cp .env.example .env
# Fill in your values, then start:  docker compose up -d
# ─────────────────────────────────────────────────────────────────────

# ── Database (required) ─────────────────────────────────────────────
# For docker compose the DATABASE_URL is auto-constructed; set these:
PGDATABASE=aithon_shield
PGUSER=aithon
PGPASSWORD=CHANGE_ME_strong_random_password
PGHOST=db
PGPORT=5432

# If running outside Docker, set the full URL directly:
# DATABASE_URL=postgresql://aithon:password@localhost:5432/aithon_shield

# ── Application ─────────────────────────────────────────────────────
PORT=5001
NODE_ENV=production
SESSION_SECRET=CHANGE_ME_random_64_char_string
ENCRYPTION_KEY=CHANGE_ME_random_32_byte_hex_key

# ── Self-hosted flag (set automatically by docker-compose) ──────────
# AITHON_SELF_HOSTED=true

# ── Demo mode (optional — development only) ─────────────────────────
# AITHON_DEMO_MODE=true

# ── AI providers (optional — leave blank to disable Shield Advisor) ─
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_AI_API_KEY=...
# MISTRAL_API_KEY=...

# ── Git integrations (optional) ─────────────────────────────────────
# GITHUB_APP_ID=
# GITHUB_APP_PRIVATE_KEY=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITLAB_APP_ID=
# GITLAB_APP_SECRET=

# ── Stripe (optional — for billing/plans) ───────────────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_STARTER=price_...
# STRIPE_PRICE_PRO=price_...
# APP_BASE_URL=https://your-app.example.com
# TRUST_PROXY=1                    # behind nginx / load balancer (correct client IP & proto)
# COOKIE_SECURE=false                # set false for plain-HTTP deployments (default: true in production)
# API_LOG_RESPONSES=true           # log JSON response bodies for /api (default: off in production)

# ── Push notifications (optional — auto-generated if missing) ───────
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=

# ── SSO / OIDC (optional) ──────────────────────────────────────────
# OIDC_ISSUER_URL=
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=

# ── Expose database port externally (optional, default 5432) ────────
# DB_EXTERNAL_PORT=5432
